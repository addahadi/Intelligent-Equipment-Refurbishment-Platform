# ─── Database (Supabase Transaction Pooler connection string) ───────────────
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@<host>:6543/postgres

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Cloudinary ─────────────────────────────────────────────────────────────
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>  (no angle brackets)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Seed ───────────────────────────────────────────────────────────────────
ADMIN_SEED_PASSWORD=admin
